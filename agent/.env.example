# ── Spectra RoutingGuardAgent — environment ──────────────────────────────────
# Copy this file to .env and fill in the values for your deployment.

# HTTP port the agent (and its WebSocket dashboard feed) listens on
PORT=3001

# Identifier this agent registers/updates itself under in the AgentRegistry
AGENT_ID=spectra-routing-guard-v1

# Public key (hex, with 01/02 prefix) the agent expects x402 payments to
# arrive at. This is the `payTo` field in every PaymentRequirements object.
AGENT_WALLET_PUBLIC_KEY=

# Contract hash (hex, no "hash-" prefix) of the deployed AgentRegistry
# contract. Leave blank to run with local-only (in-memory) reputation
# scoring — the agent will log "[rep] local only" and skip on-chain writes.
AGENT_REGISTRY_HASH=

# Path to the PEM-encoded Ed25519 secret key used to SIGN the
# update_reputation deploy sent to the AgentRegistry contract.
# This is the agent's own operating key — NOT a user's wallet key.
# Casper wallet-extension signing (for end users paying via x402) happens
# client-side; the agent never touches a user's private key.
AGENT_PRIVATE_KEY_PATH=./keys/secret_key.pem

# Casper Node RPC endpoint (testnet by default)
CSPR_NODE_RPC=https://node.testnet.cspr.cloud
CASPER_NETWORK_NAME=casper-test

# CSPR.cloud hosted x402 Facilitator (shared infra — no facilitator to run
# yourself). Same URL on mainnet and testnet.
X402_FACILITATOR=https://x402-facilitator.cspr.cloud

# CSPR.trade public MCP server (24 read-only market/analysis tools, no
# API key required)
CSPR_TRADE_MCP_URL=https://mcp.cspr.trade/mcp

# Routing fee charged per /route call, in motes (1 CSPR = 1e9 motes)
ROUTING_FEE_MOTES=100000000

# Price-impact thresholds (%) for the shield
IMPACT_WARN=1.0
IMPACT_BLOCK=5.0

# How many hourly candles to pull for volatility calculation
VOLATILITY_HOURS=24

# Max bisection probes when suggesting a reduced "optimal size"
OPTIMAL_SIZE_ITERATIONS=5
