# Used by install.mjs / register-agent.mjs / get-agent.mjs

CSPR_NODE_RPC=https://node.testnet.cspr.cloud
CASPER_NETWORK_NAME=casper-test

# Key used to sign the install / register_agent deploys (this account
# pays gas and, if STAKE_MOTES > 0, posts the agent's stake)
DEPLOYER_PRIVATE_KEY_PATH=./keys/secret_key.pem

AGENT_REGISTRY_HASH=
AGENT_ID=spectra-routing-guard-v1
STAKE_MOTES=0
